# Copy this file to .env or .env.local and fill in your actual values
# DO NOT commit .env or .env.local to git - add them to .gitignore

# GitHub API token for syncing repositories
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube API key for searching and syncing videos
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key (optional, only if using OpenAI as LLM provider)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API key (optional, only if using Groq as LLM provider)
# Get from: https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OneDrive configuration (optional, only if enabled)
ONEDRIVE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
